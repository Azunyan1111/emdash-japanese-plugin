{
	"name": "emdash-japanese-plugin",
	"version": "0.1.0",
	"description": "EmDash の管理画面を日本語化するプラグインです。メニュー、ラベル、ボタン、プレースホルダー、各種案内文を日本語で表示します。",
	"type": "module",
	"main": "./dist/src/descriptor.js",
	"types": "./dist/src/descriptor.d.ts",
	"exports": {
		".": {
			"types": "./dist/src/descriptor.d.ts",
			"import": "./dist/src/descriptor.js"
		},
		"./plugin": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		},
		"./admin": {
			"types": "./dist/src/admin.d.ts",
			"import": "./dist/src/admin.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"extract:catalog": "node ./src/generate-catalog.ts",
		"test": "vitest run",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"keywords": [
		"emdash",
		"plugin",
		"cms",
		"japanese",
		"i18n",
		"localization",
		"translation"
	],
	"author": "Azunyan1111",
	"license": "MIT",
	"homepage": "https://github.com/Azunyan1111/emdash-japanese-plugin",
	"bugs": {
		"url": "https://github.com/Azunyan1111/emdash-japanese-plugin/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Azunyan1111/emdash-japanese-plugin.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"emdash": "^0.1.0",
		"react": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@types/react": "19.2.14",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
